<data>
    <xpath expr="//group[@id='checkboxes']" position="inside">
        <label name="contain_ethanol"/>
        <field name="contain_ethanol" xexpand="0" width="25"/>
    </xpath>
    <xpath expr="//notebook" position="inside">
        <page string="Ethanol" id="ethanol">
            <label name="ethanol_by_volume"/>
            <group col="-1" id="ethanol_by_volume">
                <field name="ethanol_by_volume" factor="100" xexpand="0"/>
                <label name="ethanol_by_volume" string="%" xalign="0" xexpand="1"/>
            </group>
        </page>
    </xpath>
</data>
