<data>
    <xpath expr="//field[@name='product']" position="after">
        <field name="ethanol_by_volume" factor="100" optional="1">
            <suffix name="ethanol_by_volume" string="%"/>
        </field>
    </xpath>
    <xpath expr="//field[@name='quantity']" position="after">
        <field name="ethanol_volume" symbol="ethanol_volume_unit" optional="1"/>
    </xpath>
</data>
