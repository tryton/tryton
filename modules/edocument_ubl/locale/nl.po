"%(company)s"

#, python-format
msgctxt "model:ir.message,text:msg_credit_note_type_code_unsupported"
msgid "Unsupported credit note type code \"%(type_code)s\"."
msgstr "Creditnota code \"%(type_code)s\" is niet ondersteund."

